# ---- Africa Gigsters environment variables ----
# Copy this file to ".env" and fill in real values.

# MongoDB Atlas connection string (create a NEW database for Gigsters)
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/gigsters

# JWT signing secret — make this long and random (32+ chars)
JWT_SECRET=change_me_to_a_long_random_string

# Optional
NODE_ENV=production
PORT=3000
FRONTEND_URL=*
