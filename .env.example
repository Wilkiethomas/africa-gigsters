# ---- Africa Gigsters environment variables ----
# Copy this file to ".env" for local dev, or paste these into Hostinger's
# Environment Variables panel for production.

# Database
MONGODB_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/gigsters

# JWT signing secret — long and random (32+ chars)
JWT_SECRET=change_me_to_a_long_random_string

# Cloudflare R2 (image storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET_NAME=gigsters-media
R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev
R2_JURISDICTION=eu

# Stripe (payments) — added in Lesson 4
# Use sk_test_... keys first; swap to sk_live_... after validating the flow.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
PLATFORM_URL=https://africagigsters.com

# Optional
NODE_ENV=production
PORT=3000
FRONTEND_URL=*
